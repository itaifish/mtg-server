# Copy this to .env.test and fill in real values.
# Run: ./setup-test-env.sh   (fetches values from AWS automatically)
# Or manually:
#   VITE_API_URL: aws cloudformation describe-stacks --stack-name Deploy-test-MtgServer-test --query "Stacks[0].Outputs[?OutputKey=='ApiUrl'].OutputValue" --output text
#   VITE_API_KEY: aws apigateway get-api-key --api-key <IntegTestApiKeyId output> --include-value --query value --output text
VITE_API_URL=https://REPLACE_ME.execute-api.us-east-1.amazonaws.com/test
VITE_API_KEY=REPLACE_ME

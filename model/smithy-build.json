{
  "version": "1.0",
  "projections": {
    "mtg-server-sdk": {
      "imports": ["src/main/smithy/main.smithy"],
      "plugins": {
        "rust-server-codegen": {
          "service": "com.mtg.server#MtgService",
          "module": "mtg-server-sdk",
          "moduleDescription": "Rust server SDK for the Magic: The Gathering game server",
          "moduleVersion": "0.1.0",
          "moduleAuthors": ["MTG Server Team"],
          "runtimeConfig": {
            "version": "DEFAULT"
          }
        }
      }
    }
  }
}
